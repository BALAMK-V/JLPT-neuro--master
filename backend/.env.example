# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database (PostgreSQL)
DATABASE_URL=postgres://jlpt:jlpt@127.0.0.1:5433/jlpt_neuro_master

# CORS / CSRF (dev)
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174

# Google Gemini API — required for AI Grammar Check, Vocab Explain, Sentence Mining, AI Exam Gen
# Get a key at https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Storage
USE_S3=0
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_CUSTOM_DOMAIN=


